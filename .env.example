# Telegram bot token from @BotFather
BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# OpenClaw workspace path
WORKSPACE=/Users/your-user/.openclaw/workspace-main

# Comma-separated Telegram user IDs allowed to access the dashboard
ALLOWED_USER_IDS=123456789

# Local HTTP port for the dashboard server
PORT=3001

# Comma-separated workspace files to show as cards (optional, relative to WORKSPACE)
# If unset, no file cards are shown.
# CARDS=NOW.md,TASKS.md,memory/today.md
